#include "BLDCMotor.h"




DQVoltage_s voltage;
DQCurrent_s current;


uint16_t Pa_PWM = 0;
uint16_t Pb_PWM = 0;
uint16_t Pc_PWM = 0;
uint16_t Pd_PWM = 0;
uint16_t Pe_PWM = 0;
uint16_t Pf_PWM = 0;


/******************************************************************************/


void loopFOC(MOTORController *M)
{
	if(M->enable==0)return;   //没有使能，直接退出，减少资源占用
	
	
//      current = getFOCCurrents(M,M->electrical_angle);
			current = getFOCCurrents(M,M->electrical_angle_int);
      // dq轴反馈电流滤波
//					current.q = LPFoperator(&M->LPF_q,current.q);
//					current.d = LPFoperator(&M->LPF_d,current.d);
      // calculate the phase voltages
			voltage.q = PIDoperator(&M->PID_q, (M->PID_q.ref-current.q));
      voltage.d = PIDoperator(&M->PID_d, (M->PID_d.ref-current.d));

	  setPhaseVoltage(M, voltage.q, voltage.d, M->electrical_angle_int);
}
/******************************************************************************/
/******************************************************************************/

void setPhaseVoltage(MOTORController *M,float Uq, float Ud, float angle_el)
{
	static float temp = 0;
	static float ualph,ubeta,u1,u2,u3 = 0;
	static uint8_t sector = 0 ;
	static float Tx,Ty,T0,ta,tb,tc = 0.0f;
	
	Trig_Components Local_Vector_Components;
	Local_Vector_Components = MCM_Trig_Functions(angle_el);
	
	float cosAngle = Local_Vector_Components.hCos;
	float sinAngle = Local_Vector_Components.hSin;
	
	Ud = _SQRT3*Ud/voltage_power_supply;
	Uq = _SQRT3*Uq/voltage_power_supply;
	
	ualph = Ud * cosAngle - Uq * sinAngle;
	ubeta = Ud * sinAngle + Uq * cosAngle;
	
	u1 = ubeta;
	u2 = (0.866025f * ualph) -  0.5f*ubeta;
	u3 = (-0.866025f * ualph) -  0.5f*ubeta;
	
	sector = (u1 > 0.0f) + ((u2 > 0.0f)<<1) + ((u3 > 0.0f)<<2);
	
	switch(sector)
	{
		case 3:
		{
			
			Tx = u2;
			Ty = u1;
			T0 = (1 - Tx -Ty)*0.5f;
			
			if (T0<0)
			{
				temp=1/(Tx+Ty);
				Tx=Tx*temp;
				Ty=Ty*temp;
			}
			
			ta = Tx + Ty + T0;
			tb = Ty +T0;
			tc = T0;
			break;
		}
		case 1:
		{
			
			Tx = -(u2);
			Ty = -(u3);
			T0 = (1 - Tx -Ty)*0.5f;
			
			if (T0<0)
			{
				temp=1/(Tx+Ty);
				Tx=Tx*temp;
				Ty=Ty*temp;
			}
			
			ta = Ty + T0;
			tb = Tx + Ty +T0;
			tc = T0;
			break;
		}
		case 5:
		{
			
			Tx = u1;
			Ty = u3;
			T0 = (1 - Tx -Ty)*0.5f;
			
			if (T0<0)
			{
				temp=1/(Tx+Ty);
				Tx=Tx*temp;
				Ty=Ty*temp;
			}
			
			ta = T0;
			tb = Tx + Ty +T0;
			tc = Ty + T0;
			break;
		}
		case 4:
		{
			
			Tx = -(u1);
			Ty = -(u2);
			T0 = (1 - Tx -Ty)*0.5f;	

			if (T0<0)
			{
				temp=1/(Tx+Ty);
				Tx=Tx*temp;
				Ty=Ty*temp;
			}
			
			ta = T0;
			tb = Ty +T0;
			tc = Tx + Ty + T0;
			break;
		}
		case 6:
		{
			
			Tx = u3;
			Ty = u2;
			T0 = (1 - Tx -Ty)*0.5f;
			
			if (T0<0)
			{
				temp=1/(Tx+Ty);
				Tx=Tx*temp;
				Ty=Ty*temp;
			}
			
			ta = Ty + T0;
			tb = T0;
			tc = Tx + Ty + T0;
			break;
		}
		case 2:
		{
			
			Tx = -(u3);
			Ty = -(u1);
			T0 = (1 - Tx -Ty)*0.5f;
			
			if (T0<0)
			{
				temp=1/(Tx+Ty);
				Tx=Tx*temp;
				Ty=Ty*temp;
			}
			
			ta = Tx + Ty + T0;
			tb = T0;
			tc = Ty + T0;
			break;
		}
	}
	if(M->id == 0)
	{
		Pa_PWM = ta*PWM_Period;
		Pb_PWM = tb*PWM_Period;
		Pc_PWM = tc*PWM_Period;
		
	
		TIMER_CH0CV(TIMER0 )=ta*PWM_Period;
        TIMER_CH1CV(TIMER0 )=tb*PWM_Period;
		TIMER_CH2CV(TIMER0 )=tc*PWM_Period;
	}
	else if(M->id ==1)
	{
		Pd_PWM = ta*PWM_Period;
		Pe_PWM = tb*PWM_Period;
		Pf_PWM = tc*PWM_Period;
		
		TIMER_CH0CV(TIMER7 )=ta*PWM_Period;
        TIMER_CH1CV(TIMER7 )=tb*PWM_Period;
		TIMER_CH2CV(TIMER7 )=tc*PWM_Period;
	}
		
	
}
/******************************************************************************/


void motorPrepos(MOTORController*M, MOTORController*N)
{
	static uint16_t prepos_flg = 0;
	
	prepos_flg++;
	if(prepos_flg <500)
	{
		M->PID_d.ref = IFCurrent;
		M->PID_q.ref = 0.0f;
		
		N->PID_d.ref = IFCurrent;
		N->PID_q.ref = 0.0f;
		
		voltage_power_supply = 48.2f;
		M0.electrical_angle_int = 16384;
		loopFOC(&M0);
		loopFOC(&M1);
	}
	else if(prepos_flg >= 500 && prepos_flg <= 1000)
	{
		M->PID_d.ref = IFCurrent;
		M->PID_q.ref = 0.0f;

		N->PID_d.ref = IFCurrent;
		N->PID_q.ref = 0.0f;
		
		voltage_power_supply = 48.2f;
		M0.electrical_angle_int = 0;
		loopFOC(&M0);
		loopFOC(&M1);
	}
	else if(prepos_flg > 1000)
	{
		M->PID_d.ref = 0.0f;
		M->PID_q.ref = CurrentLoopAngleAddInit;
		
		N->PID_d.ref = 0.0f;
		N->PID_q.ref = CurrentLoopAngleAddInit;
//		PWMShut();
		motor_status = Running;
	}

}

void VolMotorPrepos(MOTORController*M, MOTORController*N)
{
	static uint16_t prepos_flg = 0;
	
	prepos_flg++;
	if(prepos_flg <500)
	{
		
		voltage_power_supply = 50.0f;

		setPhaseVoltage(&M0,6,0,16384);
		setPhaseVoltage(&M1,6,0,16384);
	}
	else if(prepos_flg >= 500 && prepos_flg <= 1000)
	{
		voltage_power_supply =50.0f;
		setPhaseVoltage(&M0,6,0,0);
		setPhaseVoltage(&M1,6,0,0);
	}
	else if(prepos_flg > 1000)
	{

//		PWMShut();
		motor_status = Running;
	}
}

/******************************************************************************/


