void speedcapt(void)
{

//	HAL_I2C_Mem_Read_DMA(&hi2c2,SLAVE_ADDR, ANGLE_REGISTER_HIGH_ADDR, I2C_MEMADD_SIZE_8BIT, ENCODER.buf, sizeof(ENCODER.buf));
//	ENCODER.ANGLE_RAW_spd = (int16_t)(ENCODER.buf[0]<<8)|(ENCODER.buf[1]);

//	ENCODER.vari = -(ENCODER.ANGLE_RAW_spd - ENCODER.angle_old);
//	HAL_I2C_Mem_Read_DMA(&hi2c2,SLAVE_ADDR, ANGLE_REGISTER_HIGH_ADDR, I2C_MEMADD_SIZE_8BIT, buf_s, sizeof(buf_s));

//	ENCODER.ANGLE_RAW_spd = (int16_t)(buf_s[0]<<8)|(buf_s[1]);
//	ENCODER.vari = ENCODER.ANGLE_RAW_spd - ENCODER.angle_old;
		ENCODER.vari = ENCODER.ANGLE_Calib - ENCODER.angle_old;
	if(abs(ENCODER.vari)>2048)
	{
		if(ENCODER.vari > 0 )
		{
			ENCODER.vari = - (4096 % ENCODER.vari);
		}
		else
		{
			ENCODER.vari =  (4096 % ENCODER.vari);
		}
	}
	ENCODER.SPEED_ROTOR = (float)ENCODER.vari*0.244140625f;
	ENCODER.angle_old = ENCODER.ANGLE_Calib;
	
}


void speed_filter(void)
{
	static float speed_arr[10] = {0.0f};
	uint8_t i = 0, j = 0;
	float temp = 0.0;
	static uint8_t k = 0;
	ENCODER.SPEED_ROTOR_old = ENCODER.SPEED_ROTOR;

	speed_arr[k++] = ENCODER.SPEED_ROTOR_old;//保存电机转速
	if (k == 10)
	{
		for (i = 10; i >= 1; i--)//冒泡排序
		{
			for (j = 0; j < (i - 1); j++) 
			{
				if (speed_arr[j] > speed_arr[j + 1]) //数值比较 
				{ 
					temp = speed_arr[j];//数值换位
					speed_arr[j] = speed_arr[j + 1];
					speed_arr[j + 1] = temp;
				}
			}
		}
		temp = 0.0;
		for (i = 2; i < 8; i++)//去除两边高低数据
		{
			temp += speed_arr[i]; //将中间数值累加
		}
		temp /= 6;//求速度平均值
		k = 0;
		//一阶低通滤波
		//公式为：Y(n)= qX(n) + (1-q)Y(n-1)
		//其中X(n)为本次采样值；Y(n-1)为上次滤波输出值；Y(n)为本次滤波输出值，q为滤波系数
		//q值越小则上一次输出对本次输出影响越大，整体曲线越平稳，但是对于速度变化的响应也会越慢
		ENCODER.SPEED_ROTOR_FILT= (0.5f * temp) + (0.5f * ENCODER.SPEED_ROTOR_old);
//		ENCODER.SPEED_ROTOR_old = ENCODER.SPEED_ROTOR_FILT;
	}	
}

void dirJudge(void)
{

	if(ENCODER.value_vari > 0 || ENCODER.value_vari < -4000)
	{
		ENCODER.direction = 0;
	}
	
	if(ENCODER.value_vari < 0 || ENCODER.value_vari > 4000)
	{
		ENCODER.direction = 1;
	}

		if(ENCODER.value_vari > 4000)
		{
			ENCODER.turns--;
		}
		if(ENCODER.value_vari < -4000)
		{
			ENCODER.turns++;
		}
		
}

void angleAddGet(void)
{
	if(ENCODER.turns == 0)
	{
		if(ENCODER.value1 > ENCODER.value0)
		{
			ENCODER.direction = 0;
		}
		else
		{
			ENCODER.direction = 1;
		}
	}
	else if(ENCODER.turns > 0)
	{
		ENCODER.direction = 0;
	}
	else 
	{
		ENCODER.direction = 1;
	}
//	ENCODER.angle_add = ENCODER.angle_add%4096;
}

void ENCODERInit(void)
{
	
	i2cRead(I2C1 ,SLAVE_ADDR, ANGLE_REGISTER_HIGH_ADDR, 8, ENCODER.buf, sizeof(ENCODER.buf));
	ENCODER.ANGLE_RAW = (int16_t)(ENCODER.buf[0]<<8)|(ENCODER.buf[1]);
//	ENCODER.ANGLE_RAW_Poles = 0;
	
	
	ENCODER.value0 = ENCODER.ANGLE_RAW;
	ENCODER.ANGLE_ZeroBase = ENCODER.ANGLE_RAW;

	
	ENCODER.angle_old = ENCODER.ANGLE_RAW;
	ENCODER.turns = 0;
	
}