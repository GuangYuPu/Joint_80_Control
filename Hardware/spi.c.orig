	uint8_t CMD_FAST_READ_DUMMY1=1;
	wAddr[0]=Address/256;
	wAddr[1]=Address%256;
//	wAddr.Val  = Address;
	//Assert CS line
//	CSLOW();
	HAL_GPIO_WritePin(GPIOD, GPIO_PIN_3, GPIO_PIN_RESET);
	//Write Command
	HAL_SPI_Transmit(&hspi3, &CMD_FAST_READ1, 1,1000);	
	//Write Address
	HAL_SPI_Transmit(&hspi3, wAddr, 2,10000);
	//Dummy Byte
	HAL_SPI_Transmit(&hspi3,&CMD_FAST_READ_DUMMY1,1,1000);
	HAL_SPI_Receive(&hspi3,dwResult1,4,1000);
	dwResult=(((uint32_t)dwResult1[3]<<24) + 
					 ((uint32_t)dwResult1[2]<<16) +
					 ((uint32_t)dwResult1[1]<<8)  +
					 ((uint32_t)dwResult1[0]));
