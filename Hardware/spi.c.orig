spi_parameter_struct hspi3;

/* SPI3 init function */
void MX_SPI3_Init(void)
{



 
    rcu_periph_clock_enable(RCU_SPI2);

    /* SPI5 parameter config */
    hspi3.trans_mode           = SPI_TRANSMODE_FULLDUPLEX;
    hspi3.device_mode          = SPI_MASTER;
    hspi3.frame_size           = SPI_FRAMESIZE_8BIT;
    hspi3.clock_polarity_phase = SPI_CK_PL_LOW_PH_1EDGE;
    hspi3.nss                  = SPI_NSS_SOFT;
    hspi3.prescale             = SPI_PSC_2;
    hspi3.endian               = SPI_ENDIAN_MSB;

    spi_init(SPI2, &hspi3);

    /* enable SPI5 */
    spi_enable(SPI2);
  
  
  
  
}

void HAL_SPI_MspInit(spi_parameter_struct* spiHandle)
{

 
  
    rcu_periph_clock_enable(RCU_GPIOC);
    rcu_periph_clock_enable(RCU_GPIOA);

    /* PC10-LANSCK   PC11-LANSIOI  PC12-LANSIO0*/
    gpio_af_set(GPIOC, GPIO_AF_5, GPIO_PIN_10 | GPIO_PIN_11 | GPIO_PIN_12 );
    gpio_mode_set(GPIOC, GPIO_MODE_AF, GPIO_PUPD_NONE, GPIO_PIN_10 | GPIO_PIN_11 | GPIO_PIN_12 );
    gpio_output_options_set(GPIOC, GPIO_OTYPE_PP, GPIO_OSPEED_25MHZ, GPIO_PIN_10 | GPIO_PIN_11 );
    /*LAN_CS*/
  
    gpio_mode_set(GPIOA, GPIO_MODE_OUTPUT, GPIO_PUPD_PULLUP, GPIO_PIN_15);
    gpio_output_options_set(GPIOA, GPIO_OTYPE_PP, GPIO_OSPEED_50MHZ, GPIO_PIN_15);
    gpio_bit_set(GPIOA, GPIO_PIN_15); 
  
  
  
  
}

void HAL_SPI_MspDeInit(spi_parameter_struct* spiHandle)
{

 
  /* USER CODE BEGIN SPI3_MspDeInit 0 */

  /* USER CODE END SPI3_MspDeInit 0 */
    /* Peripheral clock disable */
    rcu_periph_clock_disable(RCU_SPI2);
  
    /**SPI3 GPIO Configuration    
    PB3     ------> SPI3_SCK
    PB4     ------> SPI3_MISO
    PB5     ------> SPI3_MOSI 
    */
