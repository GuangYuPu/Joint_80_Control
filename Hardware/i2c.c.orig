
#include "MyProject.h"
#include <stdbool.h>


void I2CX_init (void)
{

	 GPIO_InitTypeDef GPIO_InitStructure;
        I2C_InitTypeDef I2C_InitStructure;
        
	/* 使能APB1时钟 */
	   
       RCC_AHB1PeriphResetCmd( RCC_AHB1Periph_GPIOB, ENABLE);   
	   RCC_APB1PeriphClockCmd(RCC_APB1Periph_I2C1, ENABLE);
       GPIO_DeInit(GPIOB);
       
        /* Configure pins as AF pushpull */
	 GPIO_PinAFConfig(GPIOB,GPIO_PinSource10,GPIO_AF_I2C1);
	  GPIO_PinAFConfig(GPIOB,GPIO_PinSource11,GPIO_AF_I2C1);
	
	//GPIO
	GPIO_InitStructure.GPIO_Pin = GPIO_Pin_10 | GPIO_Pin_11;
	GPIO_InitStructure.GPIO_Mode = GPIO_Mode_AF;
	GPIO_InitStructure.GPIO_OType = GPIO_OType_PP;   //推挽复用输出
	GPIO_InitStructure.GPIO_PuPd = GPIO_PuPd_UP;  //上拉
	GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;
	GPIO_Init(GPIOB,&GPIO_InitStructure);

	  I2C_DeInit(I2C1);                                                  //复位I2C
      //GPIO_PinRemapConfig(GPIO_Remap_I2C1,ENABLE);
	  I2C_InitStructure.I2C_Mode = I2C_Mode_I2C;                         //I2C模式
	  I2C_InitStructure.I2C_DutyCycle = I2C_DutyCycle_2;                 //占空比(快速模式时)
	  I2C_InitStructure.I2C_OwnAddress1 = 0;               //设备地址
	  I2C_InitStructure.I2C_Ack = I2C_Ack_Enable;                        //应答
	  I2C_InitStructure.I2C_AcknowledgedAddress = I2C_AcknowledgedAddress_7bit;
	  I2C_InitStructure.I2C_ClockSpeed = 400000;                      //速度
	  I2C_Init(I2C1, &I2C_InitStructure);

}





/*******************************************************************************
* Function Name  :i2cRead
* Description    : IIC读
* Input          : port i2c_port
* Input          : slaveAddr：I2C从设备地址
* Input         : addrbit：设备内部地址宽度，有效值0，8，16
* Input          : 设备内部地址
* Input		 : len：读入数据长度
* output         :pdata读取到的数据
*******************************************************************************/
uint8_t IIC_read_len(uint8_t addr, uint8_t reg,uint8_t *buf ,uint8_t len)
{
	//	gpio_bit_reset(GPIOB, GPIO_PIN_12);
	
	I2CTimeout = I2CT_LONG_TIMEOUT;
	while(i2c_flag_get(I2C1, I2C_FLAG_I2CBSY))
	{
		if((I2CTimeout--) == 0) 	return 1;	
		
		
	}
    i2c_start_on_bus(I2C1);
	I2CTimeout = I2CT_FLAG_TIMEOUT;  
    while(!i2c_flag_get(I2C1, I2C_FLAG_SBSEND))
	{
		
		if((I2CTimeout--) == 0) return 1;
	}
    i2c_master_addressing(I2C1, addr, I2C_TRANSMITTER);
    while(!i2c_flag_get(I2C1, I2C_FLAG_ADDSEND))
	{if((I2CTimeout--) == 0) return 1;
	}
   i2c_flag_clear(I2C1, I2C_FLAG_ADDSEND);
    while(!i2c_flag_get(I2C1, I2C_FLAG_TBE))
	{if((I2CTimeout--) == 0) return 1;
	}
    i2c_data_transmit(I2C1, reg);
   while(!i2c_flag_get(I2C1, I2C_FLAG_BTC))
	{if((I2CTimeout--) == 0) return 1;
	}
    i2c_start_on_bus(I2C1);
    while(!i2c_flag_get(I2C1, I2C_FLAG_SBSEND))
	{if((I2CTimeout--) == 0) return 1;
	}
    /* send slave address to I2C bus */
    i2c_master_addressing(I2C1, addr, I2C_RECEIVER);
    while(!i2c_flag_get(I2C1, I2C_FLAG_ADDSEND))
	{if((I2CTimeout--) == 0) return 1;
	}
    i2c_flag_clear(I2C1, I2C_FLAG_ADDSEND);
    i2c_ackpos_config(I2C1, I2C_ACKPOS_NEXT);	// 这一步是关键
    while(len){
        if (1 == len){
            i2c_ackpos_config(I2C1, I2C_ACKPOS_CURRENT);	// 这一步是关键
            i2c_ack_config(I2C1, I2C_ACK_DISABLE);
        }
        if (i2c_flag_get(I2C1, I2C_FLAG_RBNE)){
            *buf = i2c_data_receive(I2C1);
            i2c_ack_config(I2C1, I2C_ACK_ENABLE);
            buf++;
            len--;
        }
    }
    i2c_stop_on_bus(I2C1);
    while(I2C_CTL0(I2C1) & 0x0200)
	{
		if((I2CTimeout--) == 0) return 1;
	}
	//gpio_bit_set(GPIOB, GPIO_PIN_12);
    return 0;
	
	 
}






bool i2cWrite(uint32_t i2c_x, uint8_t slaveAddr, uint8_t addrbit, uint16_t addr, uint8_t *pdata, uint16_t len)
{
  

    while(i2c_flag_get(i2c_x, I2C_FLAG_I2CBSY));

    i2c_start_on_bus(i2c_x);
    while(!i2c_flag_get(i2c_x, I2C_FLAG_SBSEND));

    i2c_master_addressing(i2c_x, slaveAddr, I2C_TRANSMITTER);
    while(!i2c_flag_get(i2c_x, I2C_FLAG_ADDSEND));
    i2c_flag_clear(i2c_x,I2C_FLAG_ADDSEND);
    while(SET != i2c_flag_get(i2c_x, I2C_FLAG_TBE));

    if(addrbit > 0)
    {
        if(addrbit == 16)
        {
            i2c_data_transmit(i2c_x, (uint8_t)(addr >> 8));
            while(!i2c_flag_get(i2c_x, I2C_FLAG_BTC));
        }
        i2c_data_transmit(i2c_x, (uint8_t)(addr & 0xff));
        while(!i2c_flag_get(i2c_x, I2C_FLAG_BTC));
    }

    while(len > 0)
    {
        i2c_data_transmit(i2c_x, *pdata);
        while(!i2c_flag_get(i2c_x, I2C_FLAG_BTC));
        pdata++;
        len--;
    }

    i2c_stop_on_bus(i2c_x);
    while(I2C_CTL0(i2c_x)&0x0200);
	

}

void i2c_bus_reset()
{
}


